// src/core/intentParser.ts

export interface ParsedIntent {
  type: string;
  confidence: number;
  payload: Record<string, any>;
}

export function parseIntent(input: string): ParsedIntent {
  const normalized = input.trim().toLowerCase();

  if (normalized.startsWith("calculate")) {
    return {
      type: "math.calculate",
      confidence: 0.92,
      payload: { expression: normalized.replace("calculate", "").trim() }
    };
  }

  if (normalized.includes("weather")) {
    return {
      type: "info.weather",
      confidence: 0.88,
      payload: {}
    };
  }

  return {
    type: "general.query",
    confidence: 0.55,
    payload: { text: input }
  };
}
